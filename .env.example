# Copy to .env and fill in.

# Google Gemini — Flash Lite, looks at the room image and emits a list
# of 3-4 word SAM3-ready segmentation prompts (colour + material + category).
# Get key from https://aistudio.google.com → API keys.
GOOGLE_API_KEY=
# Optional model override (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# Roboflow — SAM3 concept_segment
# Get key from https://app.roboflow.com → workspace settings → API keys.
ROBOFLOW_API_KEY=
# Optional: detection confidence threshold (0-1, default 0.35)
# ROBOFLOW_CONFIDENCE=0.35

# SearchAPI.io — Google Lens (search_type=products)
# Get key from https://www.searchapi.io/
SEARCH_API_KEY=
# Optional Lens config
# LENS_COUNTRY=us
# LENS_LANGUAGE=en
# LENS_MAX_PARALLEL=6

# Cloudflare R2 — S3-compatible storage for the masked cutout PNGs
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL of your R2 bucket (e.g. https://cdn.example.com or
# https://pub-xxxxxxxx.r2.dev). Object key gets appended after a `/`.
R2_PUBLIC_URL=
